# ticwatch-analyzer — configuración
# Copia este fichero a .env y rellena los valores

# Tu ww_token de Mobvoi. Encuéntralo en:
# h.mobvoi.com → DevTools (F12) → Application → Cookies → ww_token
# O en la cookie de cualquier petición a h.mobvoi.com (ver README)
WW_TOKEN=pon_aqui_tu_ww_token

# Tu account_id de Mobvoi (número de 8 dígitos).
# Lo verás en las URLs de descarga: /accounts/XXXXXXXX/records/...
ACCOUNT_ID=50017568

# Carpeta donde se guardarán los archivos .tcx descargados
TCX_DIR=tcx

# Carpeta donde se moverán los .tcx una vez importados a la BD
PROCESSED_DIR=tcx_procesados

# Ruta a la base de datos SQLite
DB_PATH=ejercicios.db

# Ruta del informe HTML generado
OUTPUT_HTML=informe.html

# Número de actividades por página al paginar la API de Mobvoi
PAGE_SIZE=50
